#Simple Password Generator
echo &amp;ldquo;This is a simple password generator&amp;rdquo; echo &amp;ldquo;Please enter the length of the password: &amp;quot; read PASS_LENGTH
for p in $(seq 1 5); do openssl rand -base64 48 | cut -c1-$PASS_LENGTH
done
